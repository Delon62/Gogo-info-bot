# Token bot Discord (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Application/Client ID (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=

# Prefix untuk command teks (opsional, default: !)
PREFIX=!

# Warna default embed dalam format hex (opsional, default: #5865F2)
DEFAULT_EMBED_COLOR=#5865F2

# Ukuran maksimal upload gambar dalam MB (opsional, default: 8)
MAX_IMAGE_SIZE_MB=8

# Lokasi file database SQLite (opsional, default: ./data/database.sqlite)
DATABASE_PATH=
