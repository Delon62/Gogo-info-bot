# Salin file ini menjadi .env dan isi nilainya

# Token bot Discord (wajib)
DISCORD_TOKEN=token_bot_anda_disini

# Client ID aplikasi Discord (wajib)
CLIENT_ID=client_id_anda_disini

# Prefix untuk command berbasis pesan (opsional, default: !)
PREFIX=!

# Warna embed default dalam format hex (opsional, default: #5865F2)
DEFAULT_EMBED_COLOR=#5865F2

# Ukuran maksimal gambar dalam MB (opsional, default: 8)
MAX_IMAGE_SIZE_MB=8

# Path penyimpanan database SQLite (opsional, default: ./data/database.sqlite)
# DATABASE_PATH=./data/database.sqlite
